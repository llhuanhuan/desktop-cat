{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-undef": "error"
  },
  "globals": {
    "electronAPI": "readonly",
    "achievements": "readonly"
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*.js", "**/*.test.js", "**/__mocks__/**/*.js"],
      "env": {
        "jest": true
      }
    }
  ]
}
